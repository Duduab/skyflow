# -----------------------------------------------------------------------------
# SkyFlow API — database connection
# -----------------------------------------------------------------------------
#
# Corporate macOS / Kerberos / GSSAPI errors ("Cannot find KDC", CORP realm):
#   Prefer IPv4 loopback + disable GSS encryption for local Postgres clients:
#     export PGGSSENCMODE=disable
#   Use 127.0.0.1 instead of localhost (avoids ::1 + odd auth negotiation).
#
# Docker Compose (from repo root: docker compose up -d):
DATABASE_URL="postgresql://skyflow:skyflow@127.0.0.1:5432/skyflow"
# In production, bound the Prisma connection pool so request bursts can't
# exhaust the DB's max_connections, e.g.:
#   DATABASE_URL="...?connection_limit=10&pool_timeout=20"
JWT_SECRET="skyflow-dev-change-in-production"
# Optional: comma-separated extra origins (e.g. https://myapp.vercel.app)
# CORS_ORIGINS=
#
# Optional SMTP — when set, admin “send document” emails PDF as attachment.
# Without SMTP, the app opens the user’s mail client (mailto) with a prefilled draft.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=SkyFlow <noreply@example.com>
#
# Optional — PDF purchase-order analysis (Anthropic + S3). Without these, the API
# still starts; only /pdf-analysis/upload and drawing preview are disabled.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_S3_BUCKET=
#
# אם משתמש תכנון (planning@…) מקבל 401 בלוגין: ודאו migrate+seed, ואימייל
# בדיוק כמו ב־DB (או הקלדה באותיות קטנות — השרת מנרמל ל־lower-case).
#
# Until role `skyflow` exists, Prisma will fail (P1010). Create it once — see
# scripts/init-db.sql (run as postgres / your superuser), then use URL above.
